{
  "name": "@workspace/base-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "rm -rf dist && tsup src/components/*.tsx src/hooks/*.ts src/lib/*.ts --format esm --dts --out-dir dist --tsconfig tsconfig.build.json && mkdir -p dist/styles && cp src/styles/*.css dist/styles/",
    "clean": "rm -rf dist"
  },
  "exports": {
    "./components/*": "./dist/components/*.js",
    "./hooks/*": "./dist/hooks/*.js",
    "./lib/*": "./dist/lib/*.js",
    "./styles/*": "./dist/styles/*"
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "react": "catalog:react19",
    "react-dom": "catalog:react19"
  },
