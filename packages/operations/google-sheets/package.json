{
  "name": "@workspace/google-sheets",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "rm -rf dist && tsup src/index.ts src/server.ts src/browser.ts --format esm --dts --out-dir dist --tsconfig tsconfig.build.json",
    "clean": "rm -rf dist",
    "test": "tsx --test src/**/*.test.ts"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "browser": "./dist/browser.js",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "default": "./dist/server.js"
    }
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@types/node": "catalog:tooling",
    "tsup": "catalog:tooling",
    "tsx": "catalog:tooling",
    "typescript": "catalog:tooling"
  }
}
