# Copy to .env.local for local development.
# This key is used by the AI SDK gateway when calling model strings
# like "google/gemini-2.0-flash" in apps/web/app/api/analyze/route.ts.
AI_GATEWAY_API_KEY=

# Optional: on Vercel deployments, OIDC auth is typically injected automatically.
# VERCEL_OIDC_TOKEN=
