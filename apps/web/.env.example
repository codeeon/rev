# Copy to apps/web/.env.local for local development.

# AI analysis route (`apps/web/app/api/analyze/route.ts`)
AI_GATEWAY_API_KEY=

# Optional: on Vercel deployments, OIDC auth is typically injected automatically.
# VERCEL_OIDC_TOKEN=

# Optional: Spreadsheet admin integration (`apps/web/lib/operations/spreadsheet.ts`)
GOOGLE_SPREADSHEET_ADMIN_ID=
GOOGLE_SPREADSHEET_QUESTIONS_RANGE=Questions!A:K
GOOGLE_SPREADSHEET_RESULTS_RANGE=Results!A:J

# Optional: service account credentials for server-side Sheets access
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY_ID=
GOOGLE_SERVICE_ACCOUNT_TOKEN_URI=https://oauth2.googleapis.com/token
GOOGLE_SERVICE_ACCOUNT_SCOPES=https://www.googleapis.com/auth/spreadsheets
GOOGLE_SERVICE_ACCOUNT_SUBJECT=
