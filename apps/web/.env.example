# Copy to apps/web/.env.local for local development.

# AI analysis route (`apps/web/app/api/analyze/route.ts`)
AI_GATEWAY_API_KEY=

# Optional: on Vercel deployments, OIDC auth is typically injected automatically.
# VERCEL_OIDC_TOKEN=

# Optional: Auth.js admin auth (`/admin`)
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
ADMIN_ALLOWED_EMAILS=
ADMIN_VIEWER_EMAILS=
ADMIN_EDITOR_EMAILS=
ADMIN_OWNER_EMAILS=
ADMIN_DEFAULT_ROLE=owner
# Optional: set when verifying Auth.js locally in production mode (`pnpm --filter web start`)
AUTH_URL=http://localhost:3000

# Optional: GA4 and Sentry public runtime values
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_APP_RELEASE=

# Optional: Sentry sampling controls
SENTRY_TRACES_SAMPLE_RATE=0.2
SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0.01
SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE=1

# Optional: Spreadsheet admin integration (`@workspace/spreadsheet-admin/server`)
GOOGLE_SPREADSHEET_ADMIN_ID=
GOOGLE_SPREADSHEET_QUESTIONS_RANGE=Questions!A:K
GOOGLE_SPREADSHEET_RESULTS_RANGE=Results!A:J
GOOGLE_SPREADSHEET_QUESTION_DRAFTS_RANGE=QuestionDrafts!A:P
GOOGLE_SPREADSHEET_APPROVAL_REQUESTS_RANGE=ApprovalRequests!A:L
GOOGLE_SPREADSHEET_ADMIN_AUDIT_RANGE=AdminAuditLog!A:H
GOOGLE_SPREADSHEET_ADMIN_ACCESS_AUDIT_RANGE=AdminAccessLog!A:H
GOOGLE_SPREADSHEET_ADMIN_MUTATION_AUDIT_RANGE=AdminMutationLog!A:H
GOOGLE_SPREADSHEET_APPROVAL_LOG_RANGE=ApprovalLog!A:J

# Optional: service account credentials for server-side Sheets access
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY_ID=
GOOGLE_SERVICE_ACCOUNT_TOKEN_URI=https://oauth2.googleapis.com/token
GOOGLE_SERVICE_ACCOUNT_SCOPES=https://www.googleapis.com/auth/spreadsheets
GOOGLE_SERVICE_ACCOUNT_SUBJECT=
