{
  "name": "rev-workspace",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "pnpm build:ui && pnpm --filter web dev",
    "build:ui": "pnpm --filter @workspace/base-ui build",
    "build": "pnpm build:ui && pnpm --filter web build",
    "lint": "pnpm --filter web lint",
    "typecheck": "pnpm build:ui && pnpm --filter web exec tsc --noEmit",
    "test:engine": "pnpm --filter web test:engine"
  }
}
