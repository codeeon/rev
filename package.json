{
  "name": "rev-workspace",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "dev": "pnpm turbo run build --filter=web... && pnpm --filter web dev",
    "check:engine-sot": "node scripts/check-engine-sot.mjs",
    "build:data": "pnpm --filter @workspace/engine-data build",
    "build:saju-core": "pnpm --filter @workspace/saju-core build",
    "build:time-inference": "pnpm --filter @workspace/time-inference build",
    "build:ui": "pnpm --filter @workspace/base-ui build",
    "build": "pnpm turbo run build --filter=web...",
    "lint": "pnpm turbo run lint --filter=web",
    "typecheck": "pnpm turbo run typecheck --filter=web",
    "test:engine": "pnpm turbo run test:engine --filter=web",
    "ci:monorepo": "pnpm run check:engine-sot && pnpm turbo run lint typecheck test:engine build --filter=web..."
  },
  "devDependencies": {
    "turbo": "catalog:tooling"
  }
}
